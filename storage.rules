rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /profiles/{userId}.jpg {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn() && request.auth.uid == userId && isImageUpload();
    }

    match /posts/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId && isImageUpload();
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
