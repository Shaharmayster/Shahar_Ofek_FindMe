<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.FindMe.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/findme_surface</item>
        <item name="cardCornerRadius">@dimen/radius_large</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">@color/findme_outline</item>
        <item name="strokeWidth">@dimen/card_stroke</item>
    </style>

    <style name="Widget.FindMe.Card.Hero" parent="@style/Widget.FindMe.Card">
        <item name="cardBackgroundColor">@color/findme_surface_tonal</item>
    </style>

    <style name="Widget.FindMe.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/findme_ripple</item>
    </style>

    <style name="Widget.FindMe.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/radius_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/findme_ripple</item>
    </style>

    <style name="Widget.FindMe.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/findme_ripple</item>
    </style>

    <style name="Widget.FindMe.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.FindMe.Component</item>
        <item name="boxStrokeColor">@color/findme_outline</item>
        <item name="boxBackgroundColor">@color/findme_surface</item>
        <item name="hintTextColor">@color/findme_on_surface_variant</item>
        <item name="android:textColorHint">@color/findme_on_surface_variant</item>
    </style>

    <style name="Widget.FindMe.Progress.Linear" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackThickness">4dp</item>
        <item name="trackCornerRadius">4dp</item>
    </style>

    <style name="Widget.FindMe.Progress.Circular" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorSize">@dimen/progress_size</item>
        <item name="trackThickness">4dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.FindMe" parent="ShapeAppearance.Material3.MediumComponent" />

    <style name="ShapeAppearanceOverlay.FindMe.Component" parent="@style/ShapeAppearanceOverlay.FindMe">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_medium</item>
    </style>

    <style name="ShapeAppearanceOverlay.FindMe.Component.Large" parent="@style/ShapeAppearanceOverlay.FindMe.Component">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_large</item>
    </style>

    <style name="ShapeAppearanceOverlay.FindMe.Media" parent="@style/ShapeAppearanceOverlay.FindMe">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_large</item>
    </style>

    <style name="ShapeAppearanceOverlay.FindMe.Circle" parent="@style/ShapeAppearanceOverlay.FindMe">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ThemeOverlay.FindMe.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Material3.BodyMedium</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.Material3.TitleLarge</item>
    </style>
</resources>
